datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  records   FinancialRecord[]
}

model FinancialRecord {
  id        Int      @id @default(autoincrement())
  amount    Float
  type      String
  category  String
  date      DateTime
  note      String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  VIEWER
  ANALYST
  ADMIN
}